# ============================================
# .htaccess for www.tkykanzai.co.jp
# ============================================

# ---- 1. HTTPS強制リダイレクト ----
# http://〜 でアクセスされたら https://〜 に転送
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Force www (任意。サブドメインwwwで統一する場合)
  # RewriteCond %{HTTP_HOST} ^tkykanzai\.co\.jp$ [NC]
  # RewriteRule ^(.*)$ https://www.tkykanzai.co.jp/$1 [L,R=301]
</IfModule>

# ---- 2. カスタム404ページ ----
ErrorDocument 404 /404.html

# ---- 3. キャッシュ制御(パフォーマンス向上) ----
<IfModule mod_expires.c>
  ExpiresActive On

  # 画像 — 1ヶ月キャッシュ
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"

  # 動画 — 1ヶ月キャッシュ
  ExpiresByType video/mp4 "access plus 1 month"

  # フォント — 1ヶ月キャッシュ
  ExpiresByType font/woff "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 month"

  # CSS / JS — 1週間キャッシュ
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"

  # HTML — 1時間キャッシュ
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ---- 4. Gzip圧縮(転送量削減) ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json text/xml application/xml image/svg+xml
</IfModule>

# ---- 5. セキュリティヘッダー ----
<IfModule mod_headers.c>
  # XSS保護
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- 6. ディレクトリ一覧表示の無効化 ----
Options -Indexes

# ---- 7. 隠しファイルへのアクセス禁止 ----
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
